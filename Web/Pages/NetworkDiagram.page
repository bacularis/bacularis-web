<%@ MasterClass="Bacularis\Web\Layouts\Main" Theme="Baculum-v2"%>
<com:TContent ID="Main">
	<header class="w3-container">
		<h5>
			<b><i class="fa fa-network-wired"></i> <%[ Network Diagram ]%></b>
			<button type="button" class="w3-button w3-green w3-margin-left" onclick="location.reload()" style="font-size: 10px">
				<i class="fa fa-sync w3-small"></i> &nbsp;<strong><%[ Refresh ]%></strong>
			</button>
		</h5>
	</header>
	<div class="w3-container">
		<div id="netdiagram" style="width: 100%; min-height: 600px; background: #1a1a2e; border-radius: 8px; padding: 20px; overflow: auto;">
			<svg id="netdiagram_svg" width="100%" height="620" xmlns="http://www.w3.org/2000/svg"></svg>
		</div>
		<div id="netdiagram_legend" style="margin-top: 16px; display: flex; gap: 24px; flex-wrap: wrap;">
			<div style="display: flex; align-items: center; gap: 6px;">
				<span style="width: 14px; height: 14px; border-radius: 50%; background: #4caf50; display: inline-block;"></span> Online
			</div>
			<div style="display: flex; align-items: center; gap: 6px;">
				<span style="width: 14px; height: 14px; border-radius: 50%; background: #ff9800; display: inline-block;"></span> Degraded
			</div>
			<div style="display: flex; align-items: center; gap: 6px;">
				<span style="width: 14px; height: 14px; border-radius: 50%; background: #f44336; display: inline-block;"></span> Offline
			</div>
			<div style="display: flex; align-items: center; gap: 6px;">
				<span style="width: 14px; height: 14px; border-radius: 50%; background: #555; display: inline-block;"></span> Unknown
			</div>
		</div>
	</div>
<script type="text/javascript">
const DIAGRAM_DATA = <%= json_encode($this->diagram_data, JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_HEX_AMP) %>;
</script>
	<com:BClientScript ScriptUrl="<%~ ../JavaScript/network-diagram.js %>" />
</com:TContent>
